{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "n00ki/lasrastart",
  "type": "project",
  "description": "The ultimate mise-en-place for your next Laravel + Svelte project",
  "keywords": [
    "laravel",
    "framework",
    "svelte"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.5",
    "inertiajs/inertia-laravel": "^3.1.1",
    "laravel/fortify": "^1.37.2",
    "laravel/framework": "^13.18",
    "laravel/tinker": "^3.0.2",
    "laravel/wayfinder": "^0.1.20"
  },
  "require-dev": {
    "barryvdh/laravel-ide-helper": "^3.7",
    "driftingly/rector-laravel": "^2.5.0",
    "fakerphp/faker": "^1.24.1",
    "larastan/larastan": "^3.10.0",
    "laravel/boost": ">=2.4.11",
    "laravel/pail": "^1.2.7",
    "laravel/pao": "^1.1.2",
    "laravel/pint": "^1.29.3",
    "laravel/sail": "^1.63.0",
    "mockery/mockery": "^1.6.12",
    "nunomaduro/collision": "^8.9.4",
    "pestphp/pest": "^4.7.4",
    "pestphp/pest-plugin-browser": "^4.3.1",
    "pestphp/pest-plugin-laravel": "^4.1",
    "pestphp/pest-plugin-type-coverage": "^4.0.4",
    "rector/rector": "^2.5.2"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-update-cmd": [
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
      "Illuminate\\Foundation\\ComposerScripts::postUpdate",
      "@php artisan boost:update --ansi",
      "@php artisan ide-helper:generate",
      "composer fix"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi",
      "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
      "@php artisan migrate --graceful --ansi"
    ],
    "dev": [
      "Composer\\Config::disableProcessTimeout",
      "pnpm exec concurrently -c '#93c5fd,#c4b5fd,#fb7185,#fdba74' 'php artisan serve' 'php artisan queue:listen --tries=1' 'php artisan pail --timeout=0' 'pnpm run dev' --names=server,queue,logs,vite --kill-others"
    ],
    "dev:ssr": [
      "pnpm run build",
      "Composer\\Config::disableProcessTimeout",
      "pnpm exec concurrently -c '#93c5fd,#c4b5fd,#fb7185,#fdba74' 'php artisan serve' 'php artisan queue:listen --tries=1' 'php artisan pail --timeout=0' 'php artisan inertia:start-ssr' --names=server,queue,logs,ssr --kill-others"
    ],
    "ssr:start": "php artisan inertia:start-ssr",
    "ssr:stop": "php artisan inertia:stop-ssr",
    "ssr:check": "php artisan inertia:check-ssr",
    "annotate": [
      "@php artisan ide-helper:generate",
      "@php artisan ide-helper:models -RW"
    ],
    "format": [
      "pint --parallel",
      "pnpm run format"
    ],
    "lint": [
      "pint --parallel --test",
      "rector --dry-run",
      "pnpm run format:check",
      "pnpm run lint"
    ],
    "fix": [
      "pint --parallel",
      "rector",
      "pnpm run fix"
    ],
    "test:type-coverage": "pest --type-coverage --min=100",
    "test:types": "phpstan analyse",
    "test:unit": "pest --parallel --testsuite Unit",
    "test:feature": "pest --parallel --testsuite Feature",
    "test:browser": "pest --parallel --testsuite Browser",
    "test:all": "pest --parallel --coverage --min=100",
    "test": [
      "@php artisan config:clear --ansi",
      "@lint",
      "@test:type-coverage",
      "@test:types",
      "@test:all"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "php-http/discovery": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
